# Provider: "mock" (works today) or "sixt" (requires partner credentials)
PROVIDER=mock

# ---- Real Sixt RENT API credentials (once your partner application is approved) ----
# Base URL and auth style come from the docs you receive after approval at
# https://developers.sixt.com/ — see docs/SIXT_API_ACCESS.md
SIXT_API_BASE_URL=
SIXT_API_KEY=
SIXT_CLIENT_ID=
SIXT_CLIENT_SECRET=

# Server
PORT=3000
